generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id             String         @id @default(cuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Extracted fields
  name           String?
  email          String?        @unique
  company        String?
  useCase        String?
  budgetRange    String?
  timeline       String?

  // Qualification
  score          LeadScore      @default(UNKNOWN)
  scoreReason    String?

  // Relations
  conversations  Conversation[]

  @@map("leads")
}

model Conversation {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  leadId    String?
  lead      Lead?     @relation(fields: [leadId], references: [id])

  sessionId String    @unique
  status    ConvStatus @default(ACTIVE)

  messages  Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role           MessageRole
  content        String
  extractedData  Json?        // partial lead fields extracted at this step

  @@map("messages")
}

enum LeadScore {
  HOT
  WARM
  COLD
  UNKNOWN
}

enum ConvStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}
