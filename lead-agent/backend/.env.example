# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/lead_agent_db"

# Server
PORT=3001
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:5173

# ── AI Provider ───────────────────────────────────────────────────────────────
# Set AI_PROVIDER to: grok | groq | openai | ollama
AI_PROVIDER=grok

# Grok (xAI) — https://console.x.ai
GROK_API_KEY=xai-...
GROK_MODEL=grok-3-mini
# Other available models: grok-3, grok-3-fast, grok-2-1212

# Groq (fast open-source models) — https://console.groq.com
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — https://platform.openai.com
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Ollama (local) — Phase 4
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:7b

# Redis (Phase 3 - BullMQ)
# REDIS_URL=redis://localhost:6379
